// ──────────────────────────────────────────────
//  JSON endpoint
// ──────────────────────────────────────────────
void handleJSON() {
  String json = "{";
  json += "\"co2\":"       + String(latestCO2, 1)      + ",";
  json += "\"temp\":"      + String(latestTemp, 1)     + ",";
  json += "\"humidity\":"  + String(latestHumidity, 1) + ",";
  json += "\"rssi\":"      + lastRSSI                  + ",";
  json += "\"snr\":"       + lastSNR                   + ",";
  json += "\"updated\":\"" + lastUpdate                + "\"";
  json += "}";
  server.send(200, "application/json", json);
}

// ──────────────────────────────────────────────
//  WiFi connect
// ──────────────────────────────────────────────
void wifiConnect() {
  Serial.printf("Connecting to %s", WIFI_SSID);
  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);

  int attempts = 0;
  while (WiFi.status() != WL_CONNECTED && attempts < 30) {
    delay(500);
    Serial.print(".");
    attempts++;
  }

  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("\nWiFi connected!");
    Serial.print("Open this in your browser: http://");
    Serial.println(WiFi.localIP());
  } else {
    Serial.println("\nWiFi failed — running without web server");
  }
}

// ──────────────────────────────────────────────
//  Parse +RCV — your original logic, extended
//  to also extract temp, humidity, RSSI, SNR
//  Format: +RCV=<addr>,<len>,<co2>,<temp>,<hum>,<RSSI>,<SNR>
// ──────────────────────────────────────────────
void parseIncoming(const String& incoming) {
  // Your original logic — first two commas to get CO2
  int firstComma  = incoming.indexOf(',');
  int secondComma = incoming.indexOf(',', firstComma + 1);
  int thirdComma  = incoming.indexOf(',', secondComma + 1);

  String sensorValue = incoming.substring(secondComma + 1, thirdComma);
  float co2 = sensorValue.toFloat();

  Serial.print("Filtered CO2 Value: ");
  Serial.println(co2);

  // Extended parsing for temp, humidity, RSSI, SNR
  int fourthComma = incoming.indexOf(',', thirdComma + 1);
  int lastComma   = incoming.lastIndexOf(',');
  int secondLast  = incoming.lastIndexOf(',', lastComma - 1);

  String temp     = incoming.substring(thirdComma + 1, fourthComma);
  String humidity = incoming.substring(fourthComma + 1, secondLast);
  String rssi     = incoming.substring(secondLast + 1, lastComma);
  String snr      = incoming.substring(lastComma + 1);

  // Update globals for web page
  latestCO2      = co2;
  latestTemp     = temp.toFloat();
  latestHumidity = humidity.toFloat();
  lastRSSI       = rssi;
  lastSNR        = snr;

  unsigned long ms = millis();
  lastUpdate = String(ms / 60000) + "m " + String((ms / 1000) % 60) + "s uptime";

}

