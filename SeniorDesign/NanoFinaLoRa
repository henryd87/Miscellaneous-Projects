// ──────────────────────────────────────────────
//  Loop
// ──────────────────────────────────────────────
void loop() {
  // Handle web requests
  server.handleClient();

  // Your original LoRa receive logic — unchanged
  if (Serial0.available()) {
    String incoming = Serial0.readStringUntil('\n');

    if (incoming.startsWith("+RCV=")) {
      parseIncoming(incoming);
    }
  }
  server.handleClient();

  // Reprint IP every 10 seconds
  static unsigned long lastPrint = 0;
  if (millis() - lastPrint > 10000) {
    if (WiFi.status() == WL_CONNECTED) {
      Serial.print(">> Website: http://");
      Serial.println(WiFi.localIP());
    } else {
      Serial.println("WiFi disconnected!");
    }
    lastPrint = millis();
  }

  if (Serial0.available()) {
    String incoming = Serial0.readStringUntil('\n');
    if (incoming.startsWith("+RCV=")) {
      parseIncoming(incoming);
    }
  }

}
